# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

DATABASE_URL=postgresql://postgres:REPLACE_DB_PASSWORD@postgres:5432/apnidunia

PORT=5000

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Set to "true" for managed cloud databases (RDS, Cloud SQL, etc.)
DB_SSL=false

# ── SMS — Fast2SMS (free Indian SMS gateway) ──────────────────────────────────
# Sign up at https://fast2sms.com → Dashboard → Dev API → copy key
FAST2SMS_API_KEY=

# ── OAuth — Social Login ───────────────────────────────────────────────────────
# Public URLs used for OAuth redirect callbacks (no trailing slash)
# Defaults to localhost in dev — set these only in production
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Google OAuth — create credentials at console.cloud.google.com
#   Authorised redirect URI: ${BACKEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth — register app at portal.azure.com → App registrations
#   Redirect URI: ${BACKEND_URL}/api/auth/microsoft/callback
#   Use "common" for personal + work accounts, or your specific tenant GUID
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=apnidunia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD

# ── Redis / Valkey ────────────────────────────────────────────────────────────
# Automatically set by docker-compose. Override here for external Redis.
# Leave empty to use in-memory fallback (single-server only).
REDIS_URL=redis://redis:6379

# ── MinIO (object storage for product images) ─────────────────────────────────
# Automatically set by docker-compose. Override for AWS S3, Cloudflare R2, etc.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=REPLACE_MINIO_USER
MINIO_SECRET_KEY=REPLACE_MINIO_SECRET
MINIO_BUCKET=apnidunia
# Public URL that browsers use to load images (host-accessible)
MINIO_PUBLIC_URL=http://localhost:9000

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email (order confirmations won't be sent).
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com
#   Use an App Password (not your account password): myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ApniDunia <noreply@apnidunia.com>
