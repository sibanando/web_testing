# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

DATABASE_URL=postgresql://postgres:REPLACE_DB_PASSWORD@postgres:5432/apnidunia

PORT=5000

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Set to "true" for managed cloud databases (RDS, Cloud SQL, etc.)
DB_SSL=false

# ── SMS — Fast2SMS (free Indian SMS gateway) ──────────────────────────────────
# Sign up at https://fast2sms.com → Dashboard → Dev API → copy key
FAST2SMS_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=apnidunia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD
